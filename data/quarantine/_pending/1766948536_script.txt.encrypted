// Refresh Quarantine List
async function refreshQuarantineList() {
    showLoading(true);
    
    try {
        const response = await fetch('/api/recovery/quarantined-files-list');
        const data = await response.json();
        
        if (data.success) {
            displayQuarantineFiles(data.files || []);
            showToast('Quarantine list refreshed', 'success');
        } else {
            showToast('Failed to refresh quarantine list: ' + data.error, 'error');
