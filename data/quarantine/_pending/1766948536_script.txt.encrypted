    pathsList.innerHTML = paths.map(path => `
        <div class="path-item">
            <span class="path-text">${path}</span>
            <button class="btn btn-danger btn-sm" onclick="removeLocalStoragePath('${path}')">
                <i class="fas fa-trash"></i>
            </button>
        </div>
    `).join('');
}

// Remove Local Storage Path
async function removeLocalStoragePath(path) {
    if (!confirm('Are you sure you want to remove this local storage path?')) {
        return;
    }
    
    try {
        const response = await fetch('/api/recovery/remove-local-storage-path', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ path: path })
        });
        
        const data = await response.json();
        
        if (data.success) {
            loadLocalStoragePaths();
            showToast('Local storage path removed', 'success');
        } else {
            showToast('Failed to remove local storage path: ' + data.error, 'error');
        }
    } catch (error) {
        console.error('Error removing local storage path:', error);
        showToast('Error removing local storage path', 'error');
    }
}


.encrypted
