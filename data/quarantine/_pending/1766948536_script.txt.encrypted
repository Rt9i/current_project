// Display Quarantine Files
function displayQuarantineFiles(files) {
    const quarantineList = document.getElementById('quarantineList');
    
    if (!quarantineList) return;
    
    if (files.length === 0) {
        quarantineList.innerHTML = '<div style="text-align: center; color: var(--text-muted); padding: 2rem;">No quarantined files</div>';
        return;
    }
    
    quarantineList.innerHTML = files.map(file => {
        const time = new Date(file.quarantine_time || Date.now()).toLocaleString();
        
        return `
            <div class="quarantine-item">
                <div class="file-info">
                    <div class="file-name">${file.original_path || file.name}</div>
                    <div class="file-details">Quarantined: ${time}</div>
                </div>
                <div class="file-actions">
                    <button class="btn btn-secondary" onclick="restoreFile('${file.id}')">
                        <i class="fas fa-undo"></i> Restore
                    </button>
                    <button class="btn btn-danger" onclick="deleteQuarantinedFile('${file.id}')">
                        <i class="fas fa-trash"></i> Delete
                    </button>
                </div>
            </div>
        `;
    }).join('');
}

