// Display Quarantine Paths
function displayQuarantinePaths(paths) {
    const pathsList = document.getElementById('quarantinePathsList');
    
    if (!pathsList) return;
    
    if (paths.length === 0) {
        pathsList.innerHTML = '<div style="text-align: center; color: var(--text-muted); padding: 1rem;">No custom paths configured</div>';
        return;
    }
    
    pathsList.innerHTML = paths.map(path => `
        <div class="path-item">
            <span class="path-text">${path}</span>
            <div class="path-actions">
                <button class="btn btn-small btn-danger" onclick="removeQuarantinePath('${path}')">
                    <i class="fas fa-trash"></i>
                </button>
            </div>
        </div>
    `).join('');
}

// Remove Quarantine Path
async function removeQuarantinePath(path) {
    if (!confirm(`Are you sure you want to remove this path: ${path}?`)) {
        return;
    }
    
    try {
        const response = await fetch('/api/recovery/local-quarantine-paths', {
            method: 'DELETE',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ path: path })
        });
        
        const data = await response.json();
        
        if (data.success) {
            loadQuarantinePaths();
            showToast(data.message, 'success');
        } else {
            showToast('Failed to remove path: ' + data.error, 'error');
        }
    } catch (error) {
        console.error('Error removing path:', error);
        showToast('Error removing path', 'error');
    }
}

// Load Google Drive Status
async function loadGoogleDriveStatus() {
    try {
        const response = await fetch('/api/recovery/google-drive-status');
        const data = await response.json();
        
        if (data.success) {
            updateGoogleDriveUI(data);
            googleDriveConnected = data.connected;
        }
    } catch (error) {
        console.error('Error loading Google Drive status:', error);
    }
}

// Update Google Drive UI
function updateGoogleDriveUI(status) {
    const statusIndicator = document.querySelector('#driveStatus .status-dot');
    const statusText = document.querySelector('#driveStatus .status-indicator span:last-child');
    const connectBtn = document.getElementById('connectGoogleDrive');
    const openBtn = document.getElementById('openGoogleDrive');
    const disconnectBtn = document.getElementById('disconnectGoogleDrive');
    
    if (status.connected) {
        statusIndicator.className = 'status-dot online';
        statusText.textContent = 'Connected to Google Drive';
        connectBtn.style.display = 'none';
        openBtn.style.display = 'inline-flex';
        disconnectBtn.style.display = 'inline-flex';
    } else {
        statusIndicator.className = 'status-dot offline';
        statusText.textContent = 'Not Connected';
        connectBtn.style.display = 'inline-flex';
        openBtn.style.display = 'none';
        disconnectBtn.style.display = 'none';
    }
}

