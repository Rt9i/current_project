// Browse Quarantine Path
function browseQuarantinePath() {
    // Create directory input element (HTML5 doesn't support directory selection directly)
    // We'll use a workaround with file input
    const input = document.createElement('input');
    input.type = 'file';
    input.webkitdirectory = true;
    input.style.display = 'none';
    
    input.addEventListener('change', function(e) {
        if (e.target.files.length > 0) {
            // Get the directory path from the first file
            const firstFile = e.target.files[0];
            const pathParts = firstFile.webkitRelativePath.split('/');
            const directoryPath = pathParts[0];
            
            document.getElementById('quarantinePath').value = directoryPath;
            showToast('Directory selected: ' + directoryPath, 'success');
        }
    });
    
    document.body.appendChild(input);
    input.click();
    document.body.removeChild(input);
}

// Add Quarantine Path
async function addQuarantinePath() {
    const pathInput = document.getElementById('quarantinePath');
    const path = pathInput.value.trim();
    
    if (!path) {
        showToast('Please enter a quarantine path', 'warning');
        return;
    }
    
    showLoading(true);
    
    try {
        const response = await fetch('/api/recovery/add-quarantine-path', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ path: path })
        });
        
        const data = await response.json();
        
        if (data.success) {
            pathInput.value = '';
            loadQuarantinePaths();
            showToast('Quarantine path added successfully', 'success');
        } else {
            showToast('Failed to add quarantine path: ' + data.error, 'error');
        }
    } catch (error) {
        console.error('Error adding quarantine path:', error);
        showToast('Error adding quarantine path', 'error');
    }
    
    showLoading(false);
}

// Load Quarantine Paths
async function loadQuarantinePaths() {
    try {
        const response = await fetch('/api/recovery/quarantine-paths');
        const data = await response.json();
        
        if (data.success) {
            displayQuarantinePaths(data.paths || []);
        }
    } catch (error) {
        console.error('Error loading quarantine paths:', error);
    }
}

// Display Quarantine Paths
