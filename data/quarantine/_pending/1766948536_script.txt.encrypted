// Display Quarantined Files
function displayQuarantinedFiles(files) {
    const quarantineList = document.getElementById('quarantineList');
    
    if (!quarantineList) return;
    
    if (files.length === 0) {
        quarantineList.innerHTML = '<div style="text-align: center; color: var(--text-muted); padding: 2rem;">No quarantined files found</div>';
        return;
    }
    
    quarantineList.innerHTML = files.map(file => `
        <div class="quarantine-item">
            <div class="quarantine-item-info">
                <div class="quarantine-item-name">${file.name || 'Unknown File'}</div>
                <div class="quarantine-item-path">${file.path || 'Unknown Path'}</div>
                <div class="quarantine-item-date">${file.date ? new Date(file.date).toLocaleString() : 'Unknown Date'}</div>
            </div>
            <div class="quarantine-item-actions">
                <button class="btn btn-small btn-secondary" onclick="restoreQuarantinedFile('${file.path}')">
                    <i class="fas fa-undo"></i>
                    Restore
                </button>
                <button class="btn btn-small btn-danger" onclick="deleteQuarantinedFile('${file.path}')">
                    <i class="fas fa-trash"></i>
                    Delete
                </button>
            </div>
        </div>
    `).join('');
}

