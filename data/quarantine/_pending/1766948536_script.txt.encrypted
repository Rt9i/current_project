// Update navigation to include recovery initialization
const originalNavigateToPage = navigateToPage;
navigateToPage = function(page) {
    originalNavigateToPage(page);
    
    if (page === 'recovery') {
        setTimeout(() => {
            initializeRecoveryPage();
        }, 100);
    }
};


// Browse File to Analyze
function browseFileToAnalyze() {
    // Create file input element
    const fileInput = document.createElement('input');
    fileInput.type = 'file';
    fileInput.accept = '*/*';
    fileInput.style.display = 'none';
    
    // Add event listener
    fileInput.addEventListener('change', function(e) {
        const file = e.target.files[0];
        if (file) {
            // For web applications, we can't get the full file path for security reasons
            // Instead, we'll show the file name and handle the file upload
            const filePathInput = document.getElementById('filePathInput');
            filePathInput.value = file.name;
            
            // Store the file object for later use
            filePathInput.fileObject = file;
            
            showToast('File selected: ' + file.name, 'success');
        }
    });
    
    // Trigger file selection
    document.body.appendChild(fileInput);
    fileInput.click();
    document.body.removeChild(fileInput);
}


// Recovery Strategy Selection
async function selectRecoveryStrategy(strategy) {
    // Remove active class from all cards
    document.querySelectorAll('.strategy-card').forEach(card => {
        card.classList.remove('active');
    });
    
    // Add active class to selected card
    document.querySelector(`[data-strategy="${strategy}"]`).classList.add('active');
    
    // Store selected strategy locally
    localStorage.setItem('recoveryStrategy', strategy);
    
    // Send to server
    showLoading(true);
    
    try {
        const response = await fetch('/api/recovery/set-strategy', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ strategy: strategy })
        });
        
        const data = await response.json();
        
        if (data.success) {
            showToast(`Recovery strategy set to: ${strategy.replace(/_/g, ' ')}`, 'success');
        } else {
            showToast('Failed to save strategy: ' + data.error, 'error');
        }
    } catch (error) {
        console.error('Error saving strategy:', error);
        showToast('Error saving strategy', 'error');
    }
    
    showLoading(false);
}

