                FROM events 
                WHERE timestamp >= ? 
                ORDER BY timestamp DESC 
                LIMIT 100
            """
            return self.fetchall(sql, (cutoff.isoformat(),))
        except Exception as e:
            log.error(f"Error getting timeline events: {e}")
            return []

