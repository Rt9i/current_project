    def queued_count(self) -> int:
        with self._queue_lock:
            return len(self._write_queue)

    def close(self):
        """إغلاق آمن: إيقاف الخيط الخلفي + تفريغ الطابور + إغلاق الاتصال."""
        self._stop_bg.set()
        if hasattr(self, "_bg_thread") and self._bg_thread.is_alive():
            self._bg_thread.join(timeout=3.0)
            if self._bg_thread.is_alive():
                log.warning("Background thread did not stop in time, forcing flush")

        # محاولة التفريغ الأخير
        try:
            self._flush_all()
        except Exception:
            log.exception("Final flush failed")

        with self._conn_lock:
            if self._conn:
                try:
                    self._conn.commit()
                except Exception:
                    log.exception("DB commit on close failed")
                try:
                    self._conn.close()
                except Exception:
                    log.exception("Error closing DB")
                self._conn = None

