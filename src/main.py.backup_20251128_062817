        self.important_files_cache = None
        self.last_important_files_load = 0
        self.important_files_ttl = 30  # 30 ثانية لـ TTL
        
        self._setup_routes()

    # ------------------ DB schema ------------------
    def _init_db_schema(self):
        if not self.db:
            return
        try:
            self.db._execute(
                """
                CREATE TABLE IF NOT EXISTS events (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    ts INTEGER NOT NULL,
                    iso TEXT NOT NULL,
                    path TEXT,
                    event TEXT,
                    status TEXT,
                    decision TEXT,
                    priority TEXT,
                    size INTEGER,
                    meta TEXT
                )
                """,
                commit=True
            )
            self.db._execute("CREATE INDEX IF NOT EXISTS idx_events_ts ON events(ts)", commit=True)
            self.db._execute("CREATE INDEX IF NOT EXISTS idx_events_path ON events(path)", commit=True)
            self.db._execute("CREATE INDEX IF NOT EXISTS idx_events_decision ON events(decision)", commit=True)
            self.db._execute("CREATE INDEX IF NOT EXISTS idx_events_status ON events(status)", commit=True)
            
            # إضافة جداول جديدة مطلوبة
            self.db._execute(
                """
                CREATE TABLE IF NOT EXISTS monitored_paths (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    path TEXT NOT NULL,
                    added_at TEXT DEFAULT CURRENT_TIMESTAMP,
                    active INTEGER DEFAULT 1
                )
                """,
                commit=True
            )
            
            self.db._execute(
                """
                CREATE TABLE IF NOT EXISTS file_events (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    path TEXT NOT NULL,
                    operation_type TEXT NOT NULL,
                    timestamp TEXT DEFAULT CURRENT_TIMESTAMP,
                    threat_score REAL DEFAULT 0.0,
                    metadata TEXT
                )
                """,
                commit=True
            )
            
            self.db._execute(
                """
                CREATE TABLE IF NOT EXISTS alerts (
                    id INTEGER PRIMARY KEY AUTOINCREMENT,
                    title TEXT NOT NULL,
                    message TEXT NOT NULL,
                    severity TEXT DEFAULT 'medium',
                    created_at TEXT DEFAULT CURRENT_TIMESTAMP,
                    status TEXT DEFAULT 'active',
                    data TEXT
                )
                """,
                commit=True
            )
            
            # إضافة الفهارس
            self.db._execute("CREATE INDEX IF NOT EXISTS idx_monitored_paths ON monitored_paths(path)", commit=True)
            self.db._execute("CREATE INDEX IF NOT EXISTS idx_file_events_path ON file_events(path)", commit=True)
            self.db._execute("CREATE INDEX IF NOT EXISTS idx_file_events_timestamp ON file_events(timestamp)", commit=True)
            self.db._execute("CREATE INDEX IF NOT EXISTS idx_alerts_status ON alerts(status)", commit=True)
            self.db._execute("CREATE INDEX IF NOT EXISTS idx_alerts_severity ON alerts(severity)", commit=True)
        except Exception:
            log.exception("Failed to initialize DB schema")

    # ------------------ YARA helper ------------------
    def _ensure_yara_scanner(self):
        ycfg = self.config.get("yara", {}) or {}
        rules_dir = ycfg.get("rules_dir") or YARA_RULES_DIR
        if not YaraScanner or not rules_dir:
            self.yara_scanner = None
            return
        try:
            if self.yara_scanner is None or str(self.yara_scanner.rules_dir) != normalize_path(rules_dir):
                self.yara_scanner = YaraScanner(rules_dir=rules_dir)
            else:
                if hasattr(self.yara_scanner, "reload_if_changed"):
                    self.yara_scanner.reload_if_changed()
                else:
                    self.yara_scanner.load_rules()
        except Exception:
            log.exception("Failed to initialize/refresh YaraScanner")
        finally:
            if not hasattr(self, "yara_scanner") or self.yara_scanner is None:
                self.yara_scanner = None

