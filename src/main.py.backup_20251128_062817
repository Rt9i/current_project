        @app.route("/api/events/recent")
        def api_events_recent():
            if not self.db:
                return jsonify({"success": False, "error": "DB disabled"}), 503

            limit = min(int(request.args.get("limit", 100)), 1000)
            path_prefix = request.args.get("path_prefix")
            since_ts = request.args.get("since_ts")
            decision = request.args.get("decision")
            status = request.args.get("status")

            where = []
            params: List[Any] = []
            if path_prefix:
                where.append("path LIKE ?")
                params.append(f"{path_prefix}%")
            if since_ts:
                try:
                    where.append("ts > ?")
                    params.append(int(since_ts))
                except Exception:
                    pass
            if decision:
                where.append("decision = ?")
                params.append(decision)
            if status:
                where.append("status = ?")
                params.append(status)

            where_sql = ("WHERE " + " AND ".join(where)) if where else ""
            sql = f"""
                SELECT id, ts, iso, path, event, status, decision, priority, size
                FROM events
                {where_sql}
                ORDER BY ts DESC
                LIMIT ?
            """
            params.append(limit)
            try:
                rows = self.db.fetchall(sql, params)
                data = [dict(r) for r in rows]
                for r in data:
                    if r.get("size") is not None:
                        try:
                            r["size_h"] = sizeof_fmt(float(r["size"]))
                        except Exception:
                            pass
                return jsonify({"success": True, "data": data})
            except Exception:
                log.exception("Failed fetching recent events")
                return jsonify({"success": False}), 500

