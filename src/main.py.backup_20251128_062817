    # ------------------ Control ------------------
    def start_monitoring(self):
        if not self.system_running:
            self.file_monitor.start_monitoring()
            self.system_running = True
            self.system_paused = False # Ensure paused is false when starting
            log.info("Monitoring started")
        return True

    def stop_monitoring(self):
        if self.system_running or self.system_paused:
            self.file_monitor.stop_monitoring()
            self.system_running = False
            self.system_paused = False
            log.info("Monitoring completely stopped")
        return True

    def pause_monitoring(self):
        if self.system_running and not self.system_paused:
            self.file_monitor.stop_monitoring()
            self.system_paused = True
            log.info("Monitoring paused (system still active)")
        return True

    def resume_monitoring(self):
        if self.system_paused and self.system_running:
            self.file_monitor.start_monitoring()
            self.system_paused = False
            log.info("Monitoring resumed")
        return True

    def run(self):
        from waitress import serve
        wi = self.config.get("web_interface", {})
        host = wi.get("host", "0.0.0.0")
        port = int(wi.get("port", 5000))
        threads = int(wi.get("threads", 8))  # عدد الـ threads للنظام
        
        log.info(f"Starting production server with Waitress at http://{host}:{port}")
        log.info(f"Configuration: threads={threads}, host={host}, port={port}")
        
        # استخدام Waitress سيرفر إنتاجي بدلاً من Flask dev server
        serve(self.app, host=host, port=port, threads=threads)

# -------------------------------------
# Entrypoint (Windows-friendly shutdown)
# -------------------------------------
def main():
    system = IntegratedRansomwareProtectionSystem()

    def _shutdown():
        log.info("Shutting down...")
        try:
            system.stop_monitoring()
        except Exception:
            pass
        try:
            if getattr(system, "response", None):
                system.response.close()
        except Exception:
            log.exception("RansomwareResponse close failed")
        try:
            if getattr(system, "db", None):
                system.db.close()
        except Exception:
            log.exception("DB close failed")
        try:
            if getattr(system, "event_pool", None):
                system.event_pool.shutdown(wait=False)
        except Exception:
            pass

    # سجل دالة الإغلاق عبر atexit لويندوز (بدون حذف دعم الإشارات)
    atexit.register(_shutdown)

    # SIGINT موجود؛ SIGTERM قد لا يكون فعّال على ويندوز في كل البيئات
    signal.signal(signal.SIGINT, lambda sig, frame: (_shutdown(), sys.exit(0)))
    if hasattr(signal, "SIGTERM"):
        try:
            signal.signal(signal.SIGTERM, lambda sig, frame: (_shutdown(), sys.exit(0)))
        except Exception:
            pass

    system.run()

