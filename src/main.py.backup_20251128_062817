        try:
            if self.event_handler and self.ml:
                self.event_handler.ai = self.ml
        except Exception:
            log.exception("Failed to inject MLDetector into event_handler")

        # Inject self log and system files exclusion into monitoring config
        try:
            import logging
            log_file = None
            handlers = []
            try:
                handlers.extend(list(logging.getLogger().handlers))
            except Exception:
                pass
            try:
                if hasattr(log, "handlers"):
                    handlers.extend(list(log.handlers))
            except Exception:
                pass
            for h in handlers:
                try:
                    bf = getattr(h, "baseFilename", None)
                    if bf:
                        log_file = bf
                        break
                except Exception:
                    continue
            
            mon = self.config.setdefault("monitoring", {})
            ex = mon.setdefault("exclude_patterns", [])
            
            # Add common system patterns to exclude
            system_patterns = [
                "enhanced_system.log",
                "__pycache__",
                "*.pyc", "*.pyo", "*.pyd",
                "*.db", "*.db-wal", "*.db-shm",
                ".git", ".svn", ".hg",
                "venv", ".venv", "env", ".env",
                "node_modules", ".npm", ".yarn",
                ".cache", ".config",
                "*.tmp", "*.swp", "*.bak",
                ".DS_Store", "Thumbs.db"
            ]
            
            # Add log file if found
            if log_file:
                ex.append(log_file)
                log.info("Injected self-log into monitoring.exclude_patterns: %s", log_file)
            
            # Add system patterns
            for pattern in system_patterns:
                if pattern not in ex:
                    ex.append(pattern)
            
            log.info("Added system exclusion patterns to monitoring: %d patterns", len(ex))
        except Exception:
            log.exception("Failed to inject self-log exclusion")

        # File monitor DB path تحت ProgramData
        filemon_db = self.paths.database_dir / "file_monitor.db"
        self.file_monitor = RealTimeFileMonitor(
            str(filemon_db),
            change_callback=self._on_file_change,
            config=self.config
        )

        # Thread pool
        max_workers = int(self.config.get("executor", {}).get("max_workers", 8))
        self.event_pool = ThreadPoolExecutor(max_workers=max_workers)

        # Flask app + CORS + Routes
        self.app = Flask(__name__, static_folder=str(self.paths.static_dir), static_url_path="/")
        CORS(self.app)
        
        # Cache for monitoring data (كما هو مطلوب في الدليل التقني)
        self.monitoring_paths_cache = None
        self.last_monitoring_paths_load = 0
        self.monitoring_cache_ttl = 30  # 30 ثانية لـ TTL
